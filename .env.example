# =============================================================
# TripBoard — Environment Variables Template
# Copy this file to .env and fill in your values.
# NEVER commit the actual .env file.
# =============================================================

# ── Application ──────────────────────────────────────────────
NODE_ENV=development
APP_URL=http://localhost:3000
API_URL=http://localhost:3001
PORT=3001

# ── Database (PostgreSQL) ────────────────────────────────────
DATABASE_URL="postgresql://tripboard:password@localhost:5432/tripboard_dev?schema=public"
DATABASE_URL_SHADOW="postgresql://tripboard:password@localhost:5432/tripboard_shadow?schema=public"

# ── Auth (NextAuth.js / Auth.js) ─────────────────────────────
NEXTAUTH_SECRET=generate-with-openssl-rand-base64-32
NEXTAUTH_URL=http://localhost:3000

# OAuth providers (optional — add the ones you enable)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# ── File Storage (S3-compatible) ─────────────────────────────
# Supports: AWS S3, Cloudflare R2, MinIO, Backblaze B2
STORAGE_PROVIDER=s3              # s3 | r2 | minio | local
STORAGE_BUCKET=tripboard-vault
STORAGE_REGION=us-east-1
STORAGE_ENDPOINT=                # Leave empty for AWS S3
STORAGE_ACCESS_KEY_ID=
STORAGE_SECRET_ACCESS_KEY=
STORAGE_PUBLIC_URL=              # CDN/public base URL if applicable

# ── Email Ingestion ──────────────────────────────────────────
# Forward-to-parse email address (e.g. via Mailgun, Postmark)
EMAIL_INBOUND_DOMAIN=inbound.yourdomain.com
EMAIL_INGEST_SECRET=random-webhook-secret-for-email-ingest
MAILGUN_API_KEY=
MAILGUN_DOMAIN=
POSTMARK_INBOUND_TOKEN=

# ── AI Provider Abstraction ──────────────────────────────────
# Primary provider: openai | anthropic | google | local
AI_PROVIDER=anthropic
AI_MODEL=claude-sonnet-4-6

ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GOOGLE_AI_API_KEY=

# ── Background Jobs / Queue ──────────────────────────────────
QUEUE_PROVIDER=bull               # bull | bullmq | inngest | pg
REDIS_URL=redis://localhost:6379

# ── OCR / Document Parsing ───────────────────────────────────
OCR_PROVIDER=tesseract            # tesseract | google-vision | aws-textract
GOOGLE_VISION_API_KEY=
AWS_TEXTRACT_REGION=us-east-1

# ── Push Notifications (Web Push / VAPID) ────────────────────
# Generate keys with: node -e "const wp=require('web-push'); console.log(JSON.stringify(wp.generateVAPIDKeys()))"
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:hello@tripboard.app
NEXT_PUBLIC_VAPID_PUBLIC_KEY=    # Same as VAPID_PUBLIC_KEY — exposed to client
CRON_SECRET=                     # Random string to secure cron endpoints

# ── Security & Rate Limiting ─────────────────────────────────
JWT_SECRET=generate-with-openssl-rand-base64-32
SESSION_MAX_AGE_SECONDS=604800    # 7 days
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100

# ── Logging ──────────────────────────────────────────────────
LOG_LEVEL=info                    # debug | info | warn | error
LOG_FORMAT=pretty                 # pretty | json

# ── Feature Flags ────────────────────────────────────────────
FEATURE_AI_EXTRACTION=true
FEATURE_EMAIL_INGESTION=true
FEATURE_OFFLINE_SYNC=false
FEATURE_COLLABORATION=false
