{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "lib": ["ES2020"],
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "outDir": "./dist",
    "rootDir": "./",
    "resolveJsonModule": true,
    "baseUrl": ".",
    "paths": {
      "@tripboard/shared": ["./packages/shared/src/index.ts"]
    }
  },
  "include": ["prisma/seed.ts", "packages/shared/src/**/*"],
  "exclude": ["node_modules"]
}
