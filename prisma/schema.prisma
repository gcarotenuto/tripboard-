// TripBoard — Prisma Schema
// Privacy-first digital travel operating system
// Generator: prisma-client-js

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["fullTextSearch", "postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  shadowDatabaseUrl = env("DATABASE_URL_SHADOW")
  extensions = [pgcrypto, pg_trgm]
}

// ─────────────────────────────────────────────────────────────
// AUTH & USERS
// ─────────────────────────────────────────────────────────────

model User {
  id            String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  email         String    @unique
  emailVerified DateTime?
  name          String?
  avatarUrl     String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  deletedAt     DateTime? // soft delete for GDPR

  // Preferences stored as JSON
  preferences   Json      @default("{}")

  // Relations
  accounts      Account[]
  sessions      Session[]
  trips         Trip[]
  documents     Document[]
  expenses      Expense[]
  journals      JournalEntry[]
  ingestTokens  IngestToken[]
  auditLogs     AuditLog[]

  @@index([email])
  @@map("users")
}

model Account {
  id                String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId            String  @db.Uuid
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  sessionToken String   @unique
  userId       String   @db.Uuid
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

// ─────────────────────────────────────────────────────────────
// TRIPS
// ─────────────────────────────────────────────────────────────

enum TripStatus {
  PLANNING
  UPCOMING
  ACTIVE
  COMPLETED
  ARCHIVED
}

model Trip {
  id          String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId      String     @db.Uuid
  title       String
  description String?    @db.Text
  status      TripStatus @default(PLANNING)
  coverImageUrl String?

  // Dates — can be fuzzy during planning
  startsAt    DateTime?
  endsAt      DateTime?
  timezone    String     @default("UTC")

  // Destination(s) — primary destination for display
  primaryDestination String?
  destinations       Json    @default("[]") // Array of {city, country, lat, lng}

  // Metadata
  tags        String[]   @default([])
  isArchived  Boolean    @default(false)
  archivedAt  DateTime?

  // AI-generated post-trip summary
  memoryCapsule Json?    // { summary, highlights, stats, generatedAt }

  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  deletedAt   DateTime?

  // Relations
  user        User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  events      TripEvent[]
  documents   Document[]
  expenses    Expense[]
  journals    JournalEntry[]
  ingestJobs  IngestJob[]
  places      TripPlace[]
  dailyBoards DailyBoard[]

  @@index([userId, status])
  @@index([userId, startsAt])
  @@map("trips")
}

// ─────────────────────────────────────────────────────────────
// TIMELINE EVENTS
// ─────────────────────────────────────────────────────────────

enum EventType {
  // Logistics
  FLIGHT
  TRAIN
  BUS
  CAR_RENTAL
  FERRY
  HOTEL
  ACCOMMODATION
  RESTAURANT
  ACTIVITY
  TOUR
  TRANSFER
  // Moments
  MOMENT
  PHOTO
  NOTE
  // Administrative
  VISA
  INSURANCE
  HEALTH
  OTHER
}

enum EventView {
  LOGISTICS // Shows in Logistics View
  MOMENTS   // Shows in Moments View
  BOTH      // Shows in both views
}

model TripEvent {
  id          String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tripId      String    @db.Uuid
  title       String
  type        EventType
  view        EventView @default(LOGISTICS)

  // Timing
  startsAt    DateTime?
  endsAt      DateTime?
  timezone    String?
  allDay      Boolean   @default(false)

  // Location
  locationName    String?
  locationAddress String?
  locationLat     Float?
  locationLng     Float?
  locationPlaceId String? // Google Places / OSM reference

  // Type-specific structured data
  details     Json      @default("{}") // flight number, booking ref, seat, etc.

  // Source tracking
  sourceDocumentId String?  @db.Uuid
  sourceType       String?  // email | pdf | ics | manual | image
  confidence       Float?   // AI extraction confidence 0-1

  // Conflicts / dedup
  isDuplicate   Boolean  @default(false)
  duplicateOfId String?  @db.Uuid

  // Display
  notes         String?  @db.Text
  emoji         String?

  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  // Relations
  trip        Trip      @relation(fields: [tripId], references: [id], onDelete: Cascade)
  document    Document? @relation(fields: [sourceDocumentId], references: [id], onDelete: SetNull)
  place       TripPlace? @relation(fields: [locationPlaceId], references: [placeId])

  @@index([tripId, startsAt])
  @@index([tripId, type])
  @@map("trip_events")
}

// ─────────────────────────────────────────────────────────────
// DOCUMENT VAULT
// ─────────────────────────────────────────────────────────────

enum DocumentType {
  BOOKING_CONFIRMATION
  FLIGHT_TICKET
  BOARDING_PASS
  HOTEL_VOUCHER
  CAR_RENTAL_VOUCHER
  TRAIN_TICKET
  TOUR_VOUCHER
  VISA
  PASSPORT
  INSURANCE
  TRAVEL_ADVISORY
  HEALTH_CERTIFICATE
  RECEIPT
  ITINERARY
  MAP
  OTHER
}

enum DocumentStatus {
  PENDING      // Just uploaded, awaiting processing
  PROCESSING   // Being parsed/extracted
  EXTRACTED    // AI extraction complete
  REVIEWED     // User has reviewed
  FAILED       // Processing failed
}

enum DocumentSource {
  EMAIL_FORWARD
  EMAIL_CONNECTOR
  PDF_UPLOAD
  IMAGE_UPLOAD
  ICS_IMPORT
  MANUAL
  API
}

model Document {
  id            String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId        String         @db.Uuid
  tripId        String?        @db.Uuid

  // File metadata
  filename      String
  mimeType      String
  fileSize      Int            // bytes
  storageKey    String         @unique // S3/R2 object key
  storageUrl    String?        // Signed or CDN URL (do not persist if signed)
  checksum      String?        // SHA-256 for dedup

  // Classification
  type          DocumentType   @default(OTHER)
  status        DocumentStatus @default(PENDING)
  source        DocumentSource

  // Raw content (for searchability — encrypted at rest via storage)
  rawText       String?        @db.Text

  // AI extraction results
  extractedData Json?          // Structured fields extracted by AI
  extractionModel String?      // Which AI model/version was used
  extractionConfidence Float?  // 0-1

  // Ingestion tracking
  ingestJobId   String?        @db.Uuid

  // User annotations
  notes         String?        @db.Text
  tags          String[]       @default([])
  isFavorite    Boolean        @default(false)

  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  deletedAt     DateTime?

  // Relations
  user          User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  trip          Trip?          @relation(fields: [tripId], references: [id], onDelete: SetNull)
  events        TripEvent[]
  ingestJob     IngestJob?     @relation(fields: [ingestJobId], references: [id], onDelete: SetNull)

  @@index([userId, tripId])
  @@index([userId, type])
  @@index([status])
  @@map("documents")
}

// ─────────────────────────────────────────────────────────────
// PLACES
// ─────────────────────────────────────────────────────────────

model TripPlace {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tripId      String   @db.Uuid
  placeId     String   // External place ID (Google Places, OSM, etc.)

  name        String
  address     String?
  city        String?
  country     String?
  lat         Float?
  lng         Float?
  category    String?  // restaurant, hotel, attraction, etc.

  // User data
  notes       String?  @db.Text
  rating      Int?     // 1-5
  visited     Boolean  @default(false)
  visitedAt   DateTime?
  isFavorite  Boolean  @default(false)

  // Source
  addedBy     String   @default("manual") // manual | ai-suggestion | import

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  trip        Trip       @relation(fields: [tripId], references: [id], onDelete: Cascade)
  events      TripEvent[]

  @@unique([tripId, placeId])
  @@index([tripId])
  @@map("trip_places")
}

// ─────────────────────────────────────────────────────────────
// JOURNAL
// ─────────────────────────────────────────────────────────────

model JournalEntry {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId      String   @db.Uuid
  tripId      String   @db.Uuid

  title       String?
  content     String   @db.Text  // Rich text / markdown
  mood        String?  // emoji or mood tag
  weather     String?

  // Location at time of writing
  locationName String?
  locationLat  Float?
  locationLng  Float?

  // Associated media
  mediaUrls   String[] @default([])

  // Timing
  entryDate   DateTime // The date the entry is about (may differ from createdAt)

  // AI assistance
  aiDraft     String?  @db.Text // AI-suggested draft
  isAiDraft   Boolean  @default(false)

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  deletedAt   DateTime?

  user        User @relation(fields: [userId], references: [id], onDelete: Cascade)
  trip        Trip @relation(fields: [tripId], references: [id], onDelete: Cascade)

  @@index([userId, tripId])
  @@index([tripId, entryDate])
  @@map("journal_entries")
}

// ─────────────────────────────────────────────────────────────
// EXPENSES
// ─────────────────────────────────────────────────────────────

enum ExpenseCategory {
  TRANSPORT
  ACCOMMODATION
  FOOD
  ACTIVITIES
  SHOPPING
  HEALTH
  COMMUNICATION
  INSURANCE
  VISA_FEES
  TIPS
  OTHER
}

enum ExpenseCurrency {
  USD EUR GBP JPY CAD AUD CHF CNY INR BRL MXN SGD HKD NOK SEK DKK PLN CZK HUF RON
}

model Expense {
  id          String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId      String          @db.Uuid
  tripId      String          @db.Uuid

  title       String
  amount      Decimal         @db.Decimal(12, 2)
  currency    ExpenseCurrency @default(USD)

  // For converted totals
  amountUsd   Decimal?        @db.Decimal(12, 2)
  exchangeRate Float?

  category    ExpenseCategory @default(OTHER)
  date        DateTime
  notes       String?         @db.Text

  // Source
  sourceDocumentId String?    @db.Uuid
  isPaid      Boolean         @default(true)
  paidBy      String?         // userId or name (for group trips)

  // Receipt
  receiptUrl  String?

  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  user        User @relation(fields: [userId], references: [id], onDelete: Cascade)
  trip        Trip @relation(fields: [tripId], references: [id], onDelete: Cascade)

  @@index([tripId, date])
  @@index([tripId, category])
  @@map("expenses")
}

// ─────────────────────────────────────────────────────────────
// DAILY BOARD
// ─────────────────────────────────────────────────────────────

model DailyBoard {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tripId      String   @db.Uuid
  date        DateTime @db.Date

  // AI-generated or user-written briefing
  morningBriefing String? @db.Text

  // Checklist items for the day
  checklist   Json    @default("[]") // [{id, text, done, order}]

  // Day summary (filled post-day or on archive)
  daySummary  String? @db.Text

  // AI-suggested reminder
  reminders   Json    @default("[]") // [{id, text, time, acknowledged}]

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  trip        Trip @relation(fields: [tripId], references: [id], onDelete: Cascade)

  @@unique([tripId, date])
  @@index([tripId])
  @@map("daily_boards")
}

// ─────────────────────────────────────────────────────────────
// INGESTION PIPELINE
// ─────────────────────────────────────────────────────────────

enum IngestJobStatus {
  QUEUED
  PROCESSING
  COMPLETED
  FAILED
  PARTIAL
}

enum IngestJobSource {
  EMAIL_FORWARD
  EMAIL_CONNECTOR
  PDF_UPLOAD
  IMAGE_UPLOAD
  ICS_IMPORT
  MANUAL
}

model IngestJob {
  id          String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId      String          @db.Uuid
  tripId      String?         @db.Uuid

  status      IngestJobStatus @default(QUEUED)
  source      IngestJobSource

  // Raw intake payload
  rawPayload  Json?           // headers, body, metadata from source

  // Processing metadata
  startedAt   DateTime?
  completedAt DateTime?
  errorMessage String?        @db.Text
  retryCount  Int             @default(0)

  // Results
  documentsCreated Int        @default(0)
  eventsCreated    Int        @default(0)

  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  user        User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  documents   Document[]

  @@index([userId, status])
  @@index([status])
  @@map("ingest_jobs")
}

model IngestToken {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId      String   @db.Uuid
  token       String   @unique @default(dbgenerated("gen_random_uuid()"))

  label       String   // e.g. "Email Forward Token", "Mailgun Webhook"
  source      String   // email_forward | mailgun | postmark | etc.
  tripId      String?  @db.Uuid // if null, auto-assign to active trip

  lastUsedAt  DateTime?
  usageCount  Int       @default(0)
  isActive    Boolean   @default(true)

  createdAt   DateTime  @default(now())
  expiresAt   DateTime?

  user        User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([token])
  @@index([userId])
  @@map("ingest_tokens")
}

// ─────────────────────────────────────────────────────────────
// AUDIT LOG
// ─────────────────────────────────────────────────────────────

model AuditLog {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId      String   @db.Uuid
  action      String   // create_trip, delete_document, export_data, etc.
  entityType  String?  // trip, document, expense, etc.
  entityId    String?  @db.Uuid
  metadata    Json?
  ipAddress   String?
  userAgent   String?
  createdAt   DateTime @default(now())

  user        User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([entityType, entityId])
  @@map("audit_logs")
}
