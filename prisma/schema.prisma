// TripBoard — Prisma Schema (SQLite for local dev)
// Switch datasource to PostgreSQL for production.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────────────────────────────────────
// AUTH & USERS
// ─────────────────────────────────────────────────────────────

model User {
  id            String    @id @default(uuid())
  email         String    @unique
  emailVerified DateTime?
  name          String?
  avatarUrl     String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  deletedAt     DateTime?
  preferences   String    @default("{}")

  accounts          Account[]
  sessions          Session[]
  trips             Trip[]
  documents         Document[]
  expenses          Expense[]
  journals          JournalEntry[]
  ingestTokens      IngestToken[]
  ingestJobs        IngestJob[]
  auditLogs         AuditLog[]
  tripMembers       TripMember[]
  pushSubscriptions PushSubscription[]

  @@index([email])
  @@map("users")
}

model Account {
  id                String  @id @default(uuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(uuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

// ─────────────────────────────────────────────────────────────
// TRIPS
// ─────────────────────────────────────────────────────────────

model Trip {
  id                 String    @id @default(uuid())
  userId             String
  title              String
  description        String?
  status             String    @default("PLANNING")
  coverImageUrl      String?
  startsAt           DateTime?
  endsAt             DateTime?
  timezone           String    @default("UTC")
  primaryDestination String?
  destinations       String    @default("[]")
  tags               String    @default("[]")
  isArchived         Boolean   @default(false)
  archivedAt         DateTime?
  memoryCapsule      String?
  budget             Float?
  budgetCurrency     String?   @default("USD")
  isPublic           Boolean   @default(false)
  shareToken         String?   @unique
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt
  deletedAt          DateTime?

  user        User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  events      TripEvent[]
  documents   Document[]
  expenses    Expense[]
  journals    JournalEntry[]
  ingestJobs  IngestJob[]
  places      TripPlace[]
  dailyBoards DailyBoard[]
  packingList PackingList?
  members     TripMember[]

  @@index([userId, status])
  @@map("trips")
}

// ─────────────────────────────────────────────────────────────
// TIMELINE EVENTS
// ─────────────────────────────────────────────────────────────

model TripEvent {
  id               String    @id @default(uuid())
  tripId           String
  title            String
  type             String
  view             String    @default("LOGISTICS")
  startsAt         DateTime?
  endsAt           DateTime?
  timezone         String?
  allDay           Boolean   @default(false)
  locationName     String?
  locationAddress  String?
  locationLat      Float?
  locationLng      Float?
  locationPlaceId  String?
  details          String    @default("{}")
  sourceDocumentId String?
  sourceType       String?
  confidence       Float?
  isDuplicate      Boolean   @default(false)
  duplicateOfId    String?
  notes            String?
  emoji            String?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  trip     Trip      @relation(fields: [tripId], references: [id], onDelete: Cascade)
  document Document? @relation(fields: [sourceDocumentId], references: [id], onDelete: SetNull)

  @@index([tripId, startsAt])
  @@map("trip_events")
}

// ─────────────────────────────────────────────────────────────
// DOCUMENT VAULT
// ─────────────────────────────────────────────────────────────

model Document {
  id                   String    @id @default(uuid())
  userId               String
  tripId               String?
  filename             String
  mimeType             String
  fileSize             Int
  storageKey           String    @unique
  type                 String    @default("OTHER")
  status               String    @default("PENDING")
  source               String
  rawText              String?
  extractedData        String?
  extractionModel      String?
  extractionConfidence Float?
  ingestJobId          String?
  notes                String?
  tags                 String    @default("[]")
  isFavorite           Boolean   @default(false)
  checksum             String?
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt
  deletedAt            DateTime?

  user      User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  trip      Trip?       @relation(fields: [tripId], references: [id], onDelete: SetNull)
  events    TripEvent[]
  ingestJob IngestJob?  @relation(fields: [ingestJobId], references: [id], onDelete: SetNull)

  @@index([userId, tripId])
  @@map("documents")
}

// ─────────────────────────────────────────────────────────────
// PLACES
// ─────────────────────────────────────────────────────────────

model TripPlace {
  id         String    @id @default(uuid())
  tripId     String
  placeId    String
  name       String
  address    String?
  city       String?
  country    String?
  lat        Float?
  lng        Float?
  category   String?
  notes      String?
  rating     Int?
  visited    Boolean   @default(false)
  visitedAt  DateTime?
  isFavorite Boolean   @default(false)
  addedBy    String    @default("manual")
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  trip Trip @relation(fields: [tripId], references: [id], onDelete: Cascade)

  @@unique([tripId, placeId])
  @@index([tripId])
  @@map("trip_places")
}

// ─────────────────────────────────────────────────────────────
// JOURNAL
// ─────────────────────────────────────────────────────────────

model JournalEntry {
  id           String    @id @default(uuid())
  userId       String
  tripId       String
  title        String?
  content      String
  mood         String?
  weather      String?
  locationName String?
  locationLat  Float?
  locationLng  Float?
  mediaUrls    String    @default("[]")
  entryDate    DateTime
  aiDraft      String?
  isAiDraft    Boolean   @default(false)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  deletedAt    DateTime?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  trip Trip @relation(fields: [tripId], references: [id], onDelete: Cascade)

  @@index([userId, tripId])
  @@map("journal_entries")
}

// ─────────────────────────────────────────────────────────────
// EXPENSES
// ─────────────────────────────────────────────────────────────

model Expense {
  id               String   @id @default(uuid())
  userId           String
  tripId           String
  title            String
  amount           Float
  currency         String   @default("USD")
  amountUsd        Float?
  exchangeRate     Float?
  category         String   @default("OTHER")
  date             DateTime
  notes            String?
  sourceDocumentId String?
  isPaid           Boolean  @default(true)
  paidBy           String?
  receiptUrl       String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  trip Trip @relation(fields: [tripId], references: [id], onDelete: Cascade)

  @@index([tripId, date])
  @@map("expenses")
}

// ─────────────────────────────────────────────────────────────
// DAILY BOARD
// ─────────────────────────────────────────────────────────────

model DailyBoard {
  id              String   @id @default(uuid())
  tripId          String
  date            DateTime
  morningBriefing String?
  checklist       String   @default("[]")
  daySummary      String?
  reminders       String   @default("[]")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  trip Trip @relation(fields: [tripId], references: [id], onDelete: Cascade)

  @@unique([tripId, date])
  @@index([tripId])
  @@map("daily_boards")
}

// ─────────────────────────────────────────────────────────────
// INGESTION PIPELINE
// ─────────────────────────────────────────────────────────────

model IngestJob {
  id               String    @id @default(uuid())
  userId           String
  tripId           String?
  status           String    @default("QUEUED")
  source           String
  rawPayload       String?
  startedAt        DateTime?
  completedAt      DateTime?
  errorMessage     String?
  retryCount       Int       @default(0)
  documentsCreated Int       @default(0)
  eventsCreated    Int       @default(0)
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  trip      Trip?      @relation(fields: [tripId], references: [id], onDelete: SetNull)
  documents Document[]

  @@index([userId, status])
  @@map("ingest_jobs")
}

model IngestToken {
  id         String    @id @default(uuid())
  userId     String
  token      String    @unique @default(uuid())
  label      String
  source     String
  tripId     String?
  lastUsedAt DateTime?
  usageCount Int       @default(0)
  isActive   Boolean   @default(true)
  createdAt  DateTime  @default(now())
  expiresAt  DateTime?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([token])
  @@map("ingest_tokens")
}

// ─────────────────────────────────────────────────────────────
// PACKING LIST
// ─────────────────────────────────────────────────────────────

model PackingList {
  id        String        @id @default(uuid())
  tripId    String        @unique
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
  items     PackingItem[]

  trip Trip @relation(fields: [tripId], references: [id], onDelete: Cascade)

  @@map("packing_lists")
}

model PackingItem {
  id       String  @id @default(uuid())
  listId   String
  name     String
  category String  @default("OTHER")
  quantity Int     @default(1)
  isPacked Boolean @default(false)
  notes    String?
  order    Int     @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  list PackingList @relation(fields: [listId], references: [id], onDelete: Cascade)

  @@index([listId])
  @@map("packing_items")
}

// ─────────────────────────────────────────────────────────────
// COLLABORATION
// ─────────────────────────────────────────────────────────────

model TripMember {
  id        String   @id @default(uuid())
  tripId    String
  userId    String
  role      String   @default("VIEWER")
  invitedBy String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  trip Trip @relation(fields: [tripId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([tripId, userId])
  @@index([userId])
  @@map("trip_members")
}

// ─────────────────────────────────────────────────────────────
// PUSH SUBSCRIPTIONS
// ─────────────────────────────────────────────────────────────

model PushSubscription {
  id        String   @id @default(uuid())
  userId    String
  endpoint  String   @unique
  p256dh    String
  auth      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("push_subscriptions")
}

// ─────────────────────────────────────────────────────────────
// AUDIT LOG
// ─────────────────────────────────────────────────────────────

model AuditLog {
  id         String   @id @default(uuid())
  userId     String
  action     String
  entityType String?
  entityId   String?
  metadata   String?
  ipAddress  String?
  userAgent  String?
  createdAt  DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@map("audit_logs")
}
